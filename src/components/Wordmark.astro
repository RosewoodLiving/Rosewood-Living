---
// Brand lockup: Rosewood Living crest medallion + typographic logotype.
// The wordmark text inherits color (currentColor) so it works on light/dark.
//   tone="auto"  → renders both crests; the nav swaps them on scroll (default)
//   tone="light" → ivory crest, for dark backgrounds (e.g. footer)
//   tone="dark"  → rosewood crest, for light backgrounds
interface Props { class?: string; tone?: "auto" | "light" | "dark" }
const { class: className = "", tone = "auto" } = Astro.props;
---

<a
  href="/"
  class:list={["group inline-flex items-center gap-3 font-display leading-none", className]}
  aria-label="Rosewood Living — home"
>
  <span
    class="crest relative block h-[2.85rem] shrink-0 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-px"
    style="aspect-ratio: 460 / 635"
    aria-hidden="true"
  >
    {
      (tone === "auto" || tone === "light") && (
        <img
          src="/media/logos/crest-light.png"
          alt=""
          width="460"
          height="635"
          data-crest="light"
          class:list={[
            "absolute inset-0 h-full w-full select-none object-contain",
            tone === "auto" && "transition-opacity duration-500",
          ]}
        />
      )
    }
    {
      (tone === "auto" || tone === "dark") && (
        <img
          src="/media/logos/crest-dark.png"
          alt=""
          width="460"
          height="635"
          data-crest="dark"
          class:list={[
            "absolute inset-0 h-full w-full select-none object-contain",
            tone === "auto" && "transition-opacity duration-500",
          ]}
        />
      )
    }
  </span>
  <span class="inline-flex items-baseline gap-[0.4em]">
    <span class="text-[1.1rem] uppercase" style="font-weight:600; letter-spacing:0.2em">Rosewood</span>
    <span class="text-[1.1rem] uppercase" style="font-weight:400; letter-spacing:0.2em; opacity:0.6">Living</span>
  </span>
</a>
