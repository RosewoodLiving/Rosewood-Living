---
interface Props {
  tone?: "ink" | "light";
  class?: string;
}
const { tone = "ink", class: className = "" } = Astro.props;
const nameColor = tone === "light" ? "#fbf6ec" : "var(--color-ink)";
const subColor = tone === "light" ? "rgba(251,246,236,0.62)" : "var(--color-muted)";
---

<a
  href="/"
  class:list={["group inline-flex items-center gap-2.5", className]}
  aria-label="Rosewood Living — home"
>
  <span
    class="grid h-8 w-8 place-items-center rounded-[0.6rem] transition-transform duration-500 group-hover:-rotate-3"
    style="background: var(--color-rosewood);"
  >
    <svg viewBox="0 0 32 32" width="18" height="18" aria-hidden="true">
      <path
        d="M16 5.5c-3.9 2.6-5.9 5.7-5.9 9.4 0 3.3 1.9 6.1 4.8 7.7V27h2.2v-4.4c2.9-1.6 4.8-4.4 4.8-7.7 0-3.7-2-6.8-5.9-9.4z"
        fill="#f3ecdf"
      ></path>
    </svg>
  </span>
  <span class="leading-none" style={`color:${nameColor}`}>
    <span class="font-display text-[1.18rem] tracking-[-0.01em]" style="font-weight:480"
      >Rosewood</span
    >
    <span class="font-display text-[1.18rem]" style={`font-weight:380;color:${subColor}`}
      >Living</span
    >
  </span>
</a>
