---
import Wordmark from "./Wordmark.astro";

const links = [
  { label: "Approach", href: "/#approach" },
  { label: "Services", href: "/#services" },
  { label: "Planning", href: "/#planning" },
  { label: "Why Rosewood", href: "/#why" },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <div
    id="nav"
    data-nav
    class="text-[#f4efe6] transition-[background-color,color,border-color,backdrop-filter] duration-500"
    style="border-bottom:1px solid transparent"
  >
    <div class="u-container flex h-[4.6rem] items-center justify-between gap-6">
      <Wordmark />

      <nav class="hidden items-center gap-9 md:flex">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-[0.72rem] uppercase tracking-[0.16em] opacity-80 transition-opacity duration-300 hover:opacity-100"
            >
              {l.label}
            </a>
          ))
        }
        <a href="/letter-of-intent" class="btn-link">
          Letter of Intent
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </nav>

      <button
        type="button"
        class="grid h-10 w-10 place-items-center md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="relative block h-3 w-[20px]">
          <span class="absolute left-0 top-0 block h-px w-[20px] bg-current transition-transform duration-500" data-bar="top"></span>
          <span class="absolute left-0 bottom-0 block h-px w-[20px] bg-current transition-transform duration-500" data-bar="bottom"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile overlay -->
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-40 flex flex-col justify-center bg-canvas px-7 opacity-0 transition-opacity duration-500 md:hidden"
  data-menu-panel
>
  <nav class="flex flex-col gap-5">
    {
      links.map((l, i) => (
        <a
          href={l.href}
          class="translate-y-5 font-display text-4xl text-ink opacity-0 transition-all duration-500"
          data-menu-item
          data-menu-link
          style={`transition-delay:${90 + i * 70}ms`}
        >
          {l.label}
        </a>
      ))
    }
    <a
      href="/letter-of-intent"
      class="btn btn-primary mt-6 w-max translate-y-5 opacity-0 transition-all duration-500"
      data-menu-item
      data-menu-link
      style="transition-delay:400ms"
    >
      Letter of Intent
      <span class="btn__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
  </nav>
</div>

<script>
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]");
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-menu-item]"));
  const barTop = document.querySelector<HTMLElement>('[data-bar="top"]');
  const barBottom = document.querySelector<HTMLElement>('[data-bar="bottom"]');

  const onScroll = () => {
    if (!nav) return;
    const solid = window.scrollY > 24;
    nav.classList.toggle("is-scrolled", solid);
    if (solid) {
      nav.style.background = "rgba(236,230,218,0.92)";
      nav.style.backdropFilter = "blur(12px)";
      nav.style.borderBottomColor = "var(--color-line)";
      nav.style.color = "var(--color-ink)";
    } else {
      nav.style.background = "transparent";
      nav.style.backdropFilter = "none";
      nav.style.borderBottomColor = "transparent";
      nav.style.color = "#f4efe6";
    }
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  let open = false;
  const setMenu = (next: boolean) => {
    open = next;
    if (!panel || !toggle) return;
    panel.classList.toggle("pointer-events-none", !open);
    panel.classList.toggle("opacity-0", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    nav?.classList.toggle("is-menu-open", open);
    document.body.style.overflow = open ? "hidden" : "";
    if (nav) {
      if (open) nav.style.color = "var(--color-ink)";
      else onScroll();
    }
    if (barTop && barBottom) {
      barTop.style.transform = open ? "translateY(6px) rotate(45deg)" : "";
      barBottom.style.transform = open ? "translateY(-5px) rotate(-45deg)" : "";
    }
    items.forEach((el) => {
      el.classList.toggle("opacity-0", !open);
      el.classList.toggle("translate-y-5", !open);
    });
  };

  toggle?.addEventListener("click", () => setMenu(!open));
  document.querySelectorAll("[data-menu-link]").forEach((a) => a.addEventListener("click", () => setMenu(false)));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) setMenu(false);
  });
</script>
