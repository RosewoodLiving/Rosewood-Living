---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LoiPreview from "../components/LoiPreview.astro";
import LoiForm from "../components/forms/LoiForm.tsx";
import loiBg from "../assets/images/loi-bg.png";

const value = [
  {
    title: "A formal expression of intent",
    body: "Confirms Rosewood Living's in-principle intent to partner on, and manage, your affordable housing.",
  },
  {
    title: "Support for your planning pathway",
    body: "The document that helps evidence the affordable-housing offer and unlock the floor-space uplift.",
  },
  {
    title: "A long-term management commitment",
    body: "Reflects our intent to manage the affordable component as a Tier 3 CHP for ~15 years from OC.",
  },
  {
    title: "Issued instantly",
    body: "Personalised to your project, downloaded the moment you submit, and emailed to you as well.",
  },
];
---

<Base
  title="Letter of Intent — Rosewood Living"
  description="Request a personalised Letter of Intent from Rosewood Living — the document that helps unlock the affordable-housing uplift and confirms our intent to manage it for the long term."
>
  <Nav />

  <main>
    <!-- HEADER -->
    <section class="relative isolate flex min-h-[62vh] items-end overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <Image
          src={loiBg}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-cover"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(180deg, rgba(36,27,20,0.5) 0%, rgba(36,27,20,0.2) 40%, rgba(36,27,20,0.6) 100%);"
        >
        </div>
      </div>

      <div class="u-container pb-[clamp(3rem,7vh,5rem)] pt-36">
        <div class="max-w-3xl" data-reveal>
          <span
            class="inline-flex items-center gap-3 text-[0.7rem] font-medium uppercase tracking-[0.32em]"
            style="color:#e4cfa6"
          >
            <span class="inline-block h-px w-8" style="background:#e4cfa6;opacity:.7"></span>
            Letter of Intent
          </span>
          <h1 class="mt-7 text-display" style="color:#f6f1e7; text-wrap:balance">
            Build with affordable housing on your side.
          </h1>
          <p class="mt-7 max-w-xl text-lead" style="color:rgba(246,241,231,0.85)">
            A personalised letter confirming our intent to manage your affordable housing —
            the document that helps unlock the planning advantages and the uplift.
          </p>
        </div>
      </div>
    </section>

    <!-- VALUE BULLETS -->
    <section class="py-[clamp(3rem,6vw,5rem)]">
      <div class="u-container">
        <div class="grid gap-px border border-line bg-line sm:grid-cols-2 lg:grid-cols-4">
          {
            value.map((v, i) => (
              <div class="bg-canvas p-7" data-reveal style={`--reveal-delay:${i * 80}ms`}>
                <span class="font-display text-[1.05rem] text-gold">{String(i + 1).padStart(2, "0")}</span>
                <h3 class="mt-4 text-[1.05rem] leading-snug" style="font-weight:500">{v.title}</h3>
                <p class="mt-3 text-[0.9rem] text-ink-soft">{v.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FORM + DOCUMENT MOCKUP -->
    <section class="pb-section">
      <div class="u-container">
        <div class="grid items-center gap-y-2 lg:grid-cols-2 lg:gap-16">
          <!-- Document preview: bleeds off the left on desktop, peeks below the form on mobile -->
          <div class="relative order-2 overflow-hidden lg:order-1 lg:min-h-[40rem]">
            <div
              class="mx-auto -mb-24 mt-6 w-max -rotate-2 lg:absolute lg:left-[-7rem] lg:top-1/2 lg:mt-0 lg:mb-0 lg:-translate-y-1/2 lg:-rotate-3"
            >
              <LoiPreview />
            </div>
            <!-- soft fade at the cut edge -->
            <div
              class="pointer-events-none absolute inset-x-0 bottom-0 h-28 lg:hidden"
              style="background: linear-gradient(to top, var(--color-canvas), transparent)"
            >
            </div>
            <div
              class="pointer-events-none absolute inset-y-0 left-0 hidden w-24 lg:block"
              style="background: linear-gradient(to right, var(--color-canvas), transparent)"
            >
            </div>
          </div>

          <!-- Form -->
          <div class="order-1 lg:order-2" data-reveal>
            <div class="rounded-[2px] border border-line bg-surface p-7 sm:p-9">
              <span class="eyebrow">Request your letter</span>
              <h2 class="mt-5 text-h2">Your details</h2>
              <p class="mt-3 mb-7 text-[0.95rem] text-ink-soft">
                We&rsquo;ll generate your personalised Letter of Intent on the spot. It&rsquo;s an
                expression of intent — not a binding contract.
              </p>
              <LoiForm client:load />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
