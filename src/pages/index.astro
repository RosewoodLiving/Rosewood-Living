---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import EnquiryForm from "../components/forms/EnquiryForm.tsx";

import courtyardImg from "../assets/images/hero.png";
import lanewayImg from "../assets/images/hero-laneway.png";
import svcManagement from "../assets/images/service-management.png";
import svcPlanning from "../assets/images/service-planning.png";
import svcCommunity from "../assets/images/service-community.png";

const proof = [
  { k: "Tier 3", v: "Community Housing Provider model" },
  { k: "~30%", v: "Floor-space uplift unlocked" },
  { k: "15 yrs", v: "Long-term management horizon" },
  { k: "NSW", v: "Specialist, statewide coverage" },
];

const services = [
  {
    n: "01",
    title: "Planning & Development",
    tagline: "Feasibility through to approval.",
    image: svcPlanning,
    alt: "Architect's table with a scale model of a residential development and material samples",
    body: "Upfront advisory to de-risk your DA and structure your affordable housing offer so it strengthens both the project design and the financial returns.",
    points: [
      "Feasibility analysis & strategic positioning",
      "Scheme optimisation for FSR / density bonuses",
      "NSW planning pathway & SEPP guidance",
      "Stakeholder & authority engagement",
    ],
  },
  {
    n: "02",
    title: "Community Housing Advisory",
    tagline: "Compliance, framework & registration.",
    image: svcCommunity,
    alt: "Rooftop communal garden terrace of a residential community at golden hour",
    body: "Specialist counsel to navigate the complex regulatory landscape, ensuring your project seamlessly aligns with NSW community housing frameworks.",
    points: [
      "Affordable & community housing eligibility matching",
      "Compliance framework & registration support",
      "Resident outcome strategies",
      "Ongoing reporting & statutory assurance",
    ],
  },
  {
    n: "03",
    title: "Tailored Property Management",
    tagline: "Asset protection & community operations.",
    image: svcManagement,
    alt: "Refined, professionally managed residential lobby and resident lounge",
    body: "End-to-end operational management of the affordable component, built around asset performance, risk mitigation, and community stability.",
    points: [
      "Targeted tenant selection & community wellbeing",
      "Building management, proactive maintenance & security",
      "Access control & programmatic leasing",
      "Fire, safety & regulatory compliance",
    ],
  },
];

const why = [
  {
    title: "Specialists, not generalists",
    body: "Community and affordable housing is all we do — so the advice you get is sharper, and the management is built for it.",
  },
  {
    title: "Securing your asset for the mandatory 15 years",
    body: "With NSW density bonuses tied to a 15-year affordable housing requirement, long-term asset protection is critical. We ensure your property remains fully compliant, high-performing, and seamlessly managed from year one to year fifteen.",
  },
  {
    title: "Advisory & management, together",
    body: "The team that advises on the scheme is the team that runs it — no hand-offs, no gaps between intent and delivery.",
  },
  {
    title: "Built around residents",
    body: "Well-run, dignified homes protect value and reputation. We manage places people are genuinely proud to live in.",
  },
];
---

<Base>
  <Nav />

  <main>
    <!-- HERO -->
    <section class="relative isolate flex min-h-[100dvh] items-center overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <Image
          src={lanewayImg}
          alt=""
          widths={[1280, 1920, 2560, 3200]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-cover"
        />
        <!-- vertical depth scrim -->
        <div
          class="absolute inset-0"
          style="background: linear-gradient(180deg, rgba(18,13,9,0.55) 0%, rgba(18,13,9,0.18) 28%, rgba(18,13,9,0.28) 60%, rgba(18,13,9,0.62) 100%);"
        >
        </div>
        <!-- diagonal readability scrim behind the copy -->
        <div
          class="absolute inset-0"
          style="background: linear-gradient(102deg, rgba(18,13,9,0.82) 0%, rgba(18,13,9,0.5) 26%, rgba(18,13,9,0.12) 52%, rgba(18,13,9,0) 72%);"
        >
        </div>
      </div>

      <div class="u-container pt-20">
        <div class="max-w-3xl" data-reveal>
          <span
            class="inline-flex items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.3em]"
            style="color:#f3ead9; text-shadow:0 1px 16px rgba(18,13,9,0.65)"
          >
            <span class="inline-block h-px w-9" style="background:#cdaf7d"></span>
            Community &amp; Affordable Housing
          </span>
          <h1
            class="mt-8 text-display"
            style="color:#f8f3ea; text-wrap:nowrap; line-height:0.98; text-shadow:0 2px 40px rgba(18,13,9,0.45)"
          >
            <span class="block">The benchmark</span>
            <span class="block">in housing.</span>
          </h1>
          <p
            class="mt-7 max-w-lg text-lead"
            style="color:rgba(248,243,234,0.92); text-shadow:0 1px 20px rgba(18,13,9,0.5)"
          >
            A specialist partner for property developers: unlocking the strategic
            advantages of affordable housing, and managing the compliance, for the long term.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href="/letter-of-intent" class="btn btn-on-dark">
              Ready for your project?
              <span class="btn__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
            </a>
            <a href="#approach" class="btn btn-outline-light">Explore our approach</a>
          </div>
        </div>
      </div>
    </section>

    <!-- POSITIONING / APPROACH -->
    <section id="approach" class="py-section">
      <div class="u-container">
        <div class="grid gap-12 lg:grid-cols-[1.05fr_1fr] lg:items-end">
          <div data-reveal>
            <span class="eyebrow">Our approach</span>
            <h2 class="mt-6 text-h1" style="text-wrap:balance">
              Protecting your yield. Elevating your asset.
            </h2>
          </div>
          <div class="space-y-5 text-ink-soft lg:pb-2" data-reveal style="--reveal-delay:120ms">
            <p>
              We believe affordable housing shouldn&rsquo;t be a constraint to design
              around — it is a strategic advantage to leverage.
            </p>
            <p>
              Rosewood Living is a market-driven CHP built to support your project&rsquo;s
              financial viability. As a private sector provider with a commercial approach,
              our success is directly aligned with yours. We partner with you to navigate
              NSW compliance, secure DA advantages, and deliver a seamless management model
              that respects your vision and secures your returns for decades.
            </p>
          </div>
        </div>

        <div class="mt-16 grid grid-cols-2 border-y border-line lg:grid-cols-4" data-reveal>
          {
            proof.map((p, i) => (
              <div
                class:list={[
                  "py-9 pr-7",
                  i !== 0 && "lg:border-l lg:border-line lg:pl-9",
                  i % 2 === 1 && "border-l border-line pl-7 lg:pl-9",
                ]}
              >
                <div class="font-display text-[2.6rem] leading-none text-rosewood">{p.k}</div>
                <p class="mt-4 text-[0.9rem] text-ink-soft">{p.v}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="py-section" style="background:var(--color-surface-2)">
      <div class="u-container">
        <div class="max-w-2xl" data-reveal>
          <span class="eyebrow">Our services</span>
          <h2 class="mt-6 text-h1" style="text-wrap:balance">
            From feasibility to long-term operations.
          </h2>
        </div>

        <div class="mt-20 flex flex-col gap-20 lg:gap-28">
          {
            services.map((s, i) => (
              <article
                class:list={[
                  "grid items-center gap-9 lg:grid-cols-2 lg:gap-16",
                  i % 2 === 1 && "lg:[&>figure]:order-2",
                ]}
                data-reveal
              >
                <figure class="group overflow-hidden">
                  <Image
                    src={s.image}
                    alt={s.alt}
                    widths={[480, 800, 1100]}
                    sizes="(min-width: 1024px) 36rem, 92vw"
                    class="aspect-[16/11] w-full object-cover transition-transform duration-[1.4s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.05]"
                  />
                </figure>

                <div>
                  <div class="flex items-baseline gap-4">
                    <span class="font-display text-[1.15rem] text-gold">{s.n}</span>
                    <span class="hr-line flex-1"></span>
                  </div>
                  <h3 class="mt-6 text-h2">{s.title}</h3>
                  <p class="mt-3 font-display text-[1.15rem] italic text-rosewood">{s.tagline}</p>
                  <p class="mt-4 text-ink-soft">{s.body}</p>
                  <ul class="mt-7 grid gap-3 sm:grid-cols-2">
                    {s.points.map((pt) => (
                      <li class="flex items-start gap-2.5 text-[0.92rem] text-ink-soft">
                        <svg
                          class="mt-[0.4rem] shrink-0 text-rosewood"
                          width="13"
                          height="13"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        {pt}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- BOARDING HOUSES / YIELD STRATEGY -->
    <section id="boarding-houses" class="py-section" style="background:var(--color-rosewood-ink); color:#ece3d4;">
      <div class="u-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-16">
          <div data-reveal>
            <span class="eyebrow" style="color:#e4cfa6">Boarding houses &amp; yield</span>
            <h2 class="mt-6 text-h1" style="color:#f6f1e7; text-wrap:balance">
              Maximising yield within the caps.
            </h2>
            <div class="mt-7 space-y-5" style="color:rgba(236,227,212,0.8)">
              <p>
                We specialise in the end-to-end management of registered boarding houses —
                keeping your asset fully eligible for land-tax exemptions under Revenue NSW
                guidelines. Resident agreements are managed meticulously to stay within the
                mandated single and double tariff caps, for both full and partial board.
              </p>
              <p>
                To protect your margins under these price ceilings, we integrate smart
                utility management — including embedded energy networks and optional on-site
                battery solutions. By bulk-purchasing electricity and data at wholesale rates
                and packaging them into residents&rsquo; board, we lower building overheads,
                keep resident costs within land-tax thresholds, and capture additional net
                yield.
              </p>
            </div>
          </div>

          <div data-reveal style="--reveal-delay:120ms">
            <div
              class="rounded-[2px] border p-7 sm:p-9"
              style="border-color:rgba(236,227,212,0.18)"
            >
              <h3
                class="text-xs font-medium uppercase tracking-[0.22em]"
                style="color:#e4cfa6"
              >
                Revenue NSW maximum weekly tariffs &mdash; 2026
              </h3>
              <table class="mt-7 w-full border-collapse text-left">
                <thead>
                  <tr style="color:rgba(236,227,212,0.55)">
                    <th class="pb-3 text-[0.78rem] font-medium">Accommodation type</th>
                    <th class="pb-3 text-right text-[0.78rem] font-medium">Single</th>
                    <th class="pb-3 text-right text-[0.78rem] font-medium">Shared / double</th>
                  </tr>
                </thead>
                <tbody style="color:#f6f1e7">
                  <tr style="border-top:1px solid rgba(236,227,212,0.16)">
                    <td class="py-4 pr-4 text-[0.95rem]">
                      Less than full board
                      <span class="block text-[0.78rem]" style="color:rgba(236,227,212,0.5)">
                        Room &amp; utilities only
                      </span>
                    </td>
                    <td class="py-4 text-right font-display text-[1.3rem] text-gold">
                      $325<span class="text-[0.72rem]">/wk</span>
                    </td>
                    <td class="py-4 text-right font-display text-[1.3rem] text-gold">
                      $534<span class="text-[0.72rem]">/wk</span>
                    </td>
                  </tr>
                  <tr style="border-top:1px solid rgba(236,227,212,0.16)">
                    <td class="py-4 pr-4 text-[0.95rem]">
                      Full board &amp; lodging
                      <span class="block text-[0.78rem]" style="color:rgba(236,227,212,0.5)">
                        Includes meals
                      </span>
                    </td>
                    <td class="py-4 text-right font-display text-[1.3rem] text-gold">
                      $482<span class="text-[0.72rem]">/wk</span>
                    </td>
                    <td class="py-4 text-right font-display text-[1.3rem] text-gold">
                      $794<span class="text-[0.72rem]">/wk</span>
                    </td>
                  </tr>
                </tbody>
              </table>
              <p
                class="mt-7 text-[0.72rem] leading-relaxed"
                style="color:rgba(236,227,212,0.45)"
              >
                Indicative maximum weekly tariffs per Revenue NSW for the 2026 land-tax year
                (Section 10Q, Land Tax Management Act 1956). Figures are subject to annual
                Revenue NSW determination &mdash; verify current thresholds before relying on
                them.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PLANNING STAGE + GENERAL ENQUIRY -->
    <section id="planning" class="py-section">
      <div class="u-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
          <div data-reveal>
            <span class="eyebrow">Planning advisory</span>
            <h2 class="mt-6 text-h1" style="text-wrap:balance">
              Still in the planning stage?
            </h2>
            <p class="mt-6 text-ink-soft">
              Whether you have a site under contract or you&rsquo;re simply exploring the
              upside, the earlier we&rsquo;re involved, the more we can unlock. We&rsquo;ll
              show you where the affordable-housing uplift fits — often around an additional
              30% — and how to design a scheme that captures it.
            </p>
            <ul class="mt-8 space-y-3.5">
              {
                [
                  "A clear read on your site's affordable-housing potential",
                  "Scheme & yield optimisation before you commit",
                  "A planning pathway that authorities respond to",
                ].map((pt) => (
                  <li class="flex items-start gap-3 text-ink-soft">
                    <svg
                      class="mt-1 shrink-0 text-rosewood"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {pt}
                  </li>
                ))
              }
            </ul>
            <div class="mt-9 overflow-hidden border border-line">
              <Image
                src={courtyardImg}
                alt="Premium low-rise residential courtyard with landscaped gardens at golden hour"
                widths={[480, 800, 1100]}
                sizes="(min-width: 1024px) 34rem, 92vw"
                class="aspect-[16/10] w-full object-cover"
              />
            </div>
          </div>

          <div data-reveal style="--reveal-delay:120ms">
            <div class="rounded-[2px] border border-line bg-surface p-7 sm:p-9">
              <h3 class="text-h3">Tell us about your project</h3>
              <p class="mt-3 mb-7 text-[0.95rem] text-ink-soft">
                A short note is all we need to point you in the right direction. No
                obligation.
              </p>
              <EnquiryForm client:visible />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY ROSEWOOD -->
    <section id="why" class="py-section" style="background:var(--color-surface-2)">
      <div class="u-container">
        <div class="max-w-2xl" data-reveal>
          <span class="eyebrow">Why Rosewood</span>
          <h2 class="mt-6 text-h1">Why developers choose us.</h2>
        </div>
        <div class="mt-16 grid gap-x-12 gap-y-12 sm:grid-cols-2">
          {
            why.map((w, i) => (
              <div class="border-t border-line-strong pt-7" data-reveal style={`--reveal-delay:${(i % 2) * 90}ms`}>
                <span class="font-display text-[1.1rem] text-gold">0{i + 1}</span>
                <h3 class="mt-4 text-h3">{w.title}</h3>
                <p class="mt-4 text-[0.96rem] text-ink-soft">{w.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CLOSING CTA -->
    <section class="py-section" style="background:var(--color-rosewood-ink); color:#f6f1e7">
      <div class="u-container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="eyebrow eyebrow--center" style="color:#e4cfa6; justify-content:center">
            Ready when you are
          </span>
          <h2 class="mt-6 text-display" style="color:#f6f1e7; text-wrap:balance">
            Ready for your project?
          </h2>
          <p class="mx-auto mt-7 max-w-xl text-lead" style="color:rgba(246,241,231,0.8)">
            Request a personalised Letter of Intent and start building with the full
            advantages of affordable housing behind you.
          </p>
          <div class="mt-10 flex justify-center">
            <a href="/letter-of-intent" class="btn btn-on-dark">
              Get your Letter of Intent
              <span class="btn__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
